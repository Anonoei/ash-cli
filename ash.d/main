function _ash_help {
    _ash_fmt_banner
    echo "Usage:  ash COMMAND"
    echo ""
    echo "CLI helper"
    echo ""
    echo "Commands:"
    echo " ASH:"
    local _ash_help_arg=(
        "h|help;show_this_message"
        "i|installation;ASH_installation_helper"
        "s|state;ASH_configuration_helper"
        "x|extra;ASH_extras"
        "e|escape;ANSI_escape_helper"
        "u|utils;ASH_utils"
        )
    _ash_fmt_help_items "${_ash_help_arg[@]}"
    echo ""
    echo "Run 'ash COMMAND help' for more information on a command"
}

if [[ "$1" == "import" ]]; then
    return
elif [[ $# -eq 0 ]]; then
    _ash_help
    return
fi

ASH_trace "main" "Start"

ASH_CMD=$1
shift
case $ASH_CMD in
    h|help|-h|--help)
        _ash_help $*
        ;;
    i|installation)
        source $ASH_ROOT/ash.d/installation $*
        ;;
    s|state)
        source $ASH_ROOT/ash.d/state $*
        ;;
    x|extra)
        source $ASH_ROOT/ash.d/extra $*
        ;;
    e|escape)
        _ash_escape $*
        ;;
    u|utils)
        source $ASH_ROOT/ash.d/utils $*
        ;;
    # Internal / not meant for CLI users
    new)
        source $ASH_ROOT/ash.d/utils new $*
        ;;
    version)
        source $ASH_ROOT/ash.d/installation version $*
        ;;
    is_updated)
        source $ASH_ROOT/ash.d/installation is_updated $*
        ;;
    git_update)
        source $ASH_ROOT/ash.d/installation git_update $*
        ;;
    *)
        _ash_fmt_help_unk "ash" $ASH_CMD $*
        ;;
esac
