echo "ash extra pkg attempting to install: $*"

case $ASH_PKGMAN in
    yum|dnf)
        sudo $ASH_PKGMAN install $*
        ;;
    apt)
        sudo $ASH_PKGMAN install $*
        ;;
    pacman)
        sudo $ASH_PKGMAN -Sy --needed $*
        ;;
    brew)
        sudo $ASH_PKGMAN install $*
        ;;
    *)
        echo "Unknown package manager: $ASH_PKGMAN"
        ;;
esac
