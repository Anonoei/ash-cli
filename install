# ASH CLI installer
# (C) Anonoei, Licenced under the MIT license

AINST_SRC="https://github.com/anonoei/ash-cli"
AINST_ROOT="${HOME}/.local/ash"
AINST_CONFIG="${HOME}/.config/ash"
# ---------------------- #

ARG_REMOVE=0

function _show_help {
    echo "ASH installer"
    echo ""
    echo "Arguments:"
    echo "  -h|--help..................show this message"
    echo "  -c|--config................delete ash/config"
}

function _parse_args {
    if [[ $# -eq 0 ]]; then
        return
    fi
    AINST_ARG=$1
    shift
    case $AINST_ARG in
        -h|--help)
            _show_help
            exit 0
            ;;
        -c|--config)
            ARG_REMOVE=1
            ;;
        *)
            echo "Unknown argument! $AINST_ARG"
            exit 1
            ;;
    esac
    _parse_args $*
}

function ash_remove_config {
    rm -rf $AINST_CONFIG
}

function ash_pre {
    [[ -d "${AINST_ROOT}" ]] && rm -rf "${AINST_ROOT}"
    mkdir -p $AINST_CONFIG/plugins
}

function ash_post {
    if [[ ! -f "$AINST_CONFIG/ash.conf" ]]; then
        echo "Copying default configuration..."
        cp $AINST_ROOT/ash.conf.defaults $AINST_CONFIG/ash.conf
    fi
}

if [ "${BASH_SOURCE[0]}" -ef "$0" ]
then
    _parse_args $*

    if [[ $ARG_REMOVE -eq 1 ]]; then
        echo "Removing $AINST_CONFIG"
        ash_remove_config
    fi

    ash_pre
    echo "Cloning ASH..."
    git clone $AINST_SRC "$AINST_ROOT"
    ash_post

    echo ""
    echo "ASH is installed!"
    echo ""
    echo "To add ASH to your shell please add the following to your RC file:"
    echo ""
    echo "source $AINST_ROOT/a.sh"
    echo ""
fi
