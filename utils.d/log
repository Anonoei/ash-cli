ASH_LOGGER_NAMES=("TRACE" "DEBUG" "INFO" "WARN" "ERROR")
ASH_LOGGER_LEVELS=(5 4 3 2 1)

function _ash_utils_log_help {
    echo "Usage:  ash utils log COMMAND"
    echo ""
    echo "ASH utils log"
    echo ""
    echo "Commands:"
    local ash_arg=(
        "help;show_this_message"
        "new;create_a_new_logger"
        "show;show_existing_loggers"
    )
    _ash_fmt_help_items "${ash_arg[@]}"
    echo ""
}

function _ash_utils_log_level_from_name {
    # $1 = name
    if [[ ! ${ASH_LOGGER_NAMES[@]} =~ "$1" ]]; then
        echo 99
        return
    fi

    for ((i=0; $i<${#ASH_LOGGER_NAMES[@]}; i++)); do
        if [[ "${ASH_LOGGER_NAMES[$i]}" == "$1" ]]; then
            echo "${ASH_LOGGER_LEVELS[$i]}"
            return
        fi
    done
}

function _ash_utils_log_level_to_name {
    # $1 = level
    if [[ ! ${ASH_LOGGER_LEVELS[@]} =~ "$1" ]]; then
        echo "NONE"
        return
    fi

    for ((i=0; $i<${#ASH_LOGGER_LEVELS[@]}; i++)); do
        if [[ "${ASH_LOGGER_LEVELS[$i]}" == "$1" ]]; then
            echo "${ASH_LOGGER_NAMES[$i]}"
            return
        fi
    done
}

if [[ "$1" == "import" ]]; then
    return
elif [[ $# -eq 0 ]]; then
    _ash_utils_log_help
    return
fi

ASH_CMD=$1
shift
case $ASH_CMD in
    help|-h|--help)
        _ash_utils_log_help $*
        ;;
    new)
        source $ASH_ROOT/utils.d/log.d/create $*
        ;;
    show)
        source $ASH_ROOT/utils.d/log.d/show $*
        ;;
    *)
        _ash_fmt_help_unk "ash utils log" $ASH_CMD $*
        ;;
esac
